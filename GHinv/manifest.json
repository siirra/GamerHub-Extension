{
  "manifest_version": 3,
  "name": "GamerHub: Ultimate Gaming Dashboard & Steam Tools",
  "version": "1.1.3",
  "description": "All-in-one Gaming Dashboard with Steam integration and Game Deals",

  "permissions": [
    "storage",
    "notifications",
    "alarms",
    "cookies"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },

  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },

  "host_permissions": [
    "https://api.steampowered.com/*",
    "https://www.cheapshark.com/*",
    "https://steamcommunity.com/*",
    "https://community.cloudflare.steamstatic.com/*",
    "https://open.faceit.com/*",
    "http://127.0.0.1/*",                 
    "https://www.gamerpower.com/*",
    "https://speed.cloudflare.com/*",
    "https://api.skinport.com/*",
    "https://raw.githubusercontent.com/*",
    "https://*.amazonaws.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://steamcommunity.com/id/*",
        "https://steamcommunity.com/profiles/*",
        "https://steamcommunity.com/inventory/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["icon.png"],
      "matches": ["https://steamcommunity.com/*"]
    }
  ]
}